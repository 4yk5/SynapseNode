{
  "manifest_version": 3,
  "name": "SynapseNode",
  "version": "1.1.0",
  "description": "An offline-first, AI-free, ultra-fast browser assistant to manage web content.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "icons": {
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": "icons/icon128.png",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["style.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
