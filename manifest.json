{
  "manifest_version": 3,
  "name": "Context-Aware Action Drawer",
  "version": "1.1.0",
  "description": "Sleek slate-sapphire & neon-cyan action drawer to Quick Search, Simplify, and Fast Pin web content.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["style.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
